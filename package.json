{
  "name": "komur-satis-otomasyonu",
  "version": "1.0.55",
  "description": "Karaarslan Kömür Satış Otomasyonu",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "start": "nodemon index.js",
    "set-version": "node scripts/set-version.js",
    "build:exe": "npx pkg index.js --targets node18-win-x64 --output dist/komur-satis-otomasyonu.exe",
    "desktop": "electron desktop-main.js",
    "build:desktop": "taskkill /F /IM \"Karaarslan Komur.exe\" >nul 2>&1 & set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win nsis",
    "build:desktop:fresh": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$ts=Get-Date -Format yyyyMMdd-HHmmss; $env:CSC_IDENTITY_AUTO_DISCOVERY='false'; npx electron-builder --win nsis --config.directories.output=dist-desktop-$ts\"",
    "publish:desktop": "taskkill /F /IM \"Karaarslan Komur.exe\" >nul 2>&1 & set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win nsis --publish always"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ]
  },
  "build": {
    "appId": "com.karaarslan.komur",
    "productName": "Karaarslan Komur",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!dist-desktop/**",
      "!dist-desktop-*/**",
      "!release-v*/**",
      "!node_modules/.cache/**"
    ],
    "extraMetadata": {
      "main": "desktop-main.js"
    },
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "bahrikarli",
        "repo": "komur-satis-otomasyonu",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.6.2",
    "express": "^4.19.2",
    "mssql": "^12.2.1",
    "mysql2": "^3.9.3"
  },
  "devDependencies": {
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12",
    "nodemon": "^3.1.0",
    "pkg": "^5.8.1"
  }
}
